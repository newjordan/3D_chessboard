{
  "name": "chess-agents",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run generate && npm run build --workspaces --if-present",
    "generate": "npm run generate --workspace @chess-agents/api && npm run generate --workspace @chess-agents/worker",
    "start": "npm run start --workspaces --if-present",
    "postinstall": "npm run generate"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "prisma": "6.2.1",
    "turbo": "latest",
    "typescript": "^5.0.0"
  }
}
