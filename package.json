{
  "name": "chess-agents",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npx prisma generate && npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present",
    "postinstall": "npx prisma generate"
  },
  "devDependencies": {
    "prisma": "^7.7.0",
    "turbo": "latest",
    "typescript": "^5.0.0"
  }
}
