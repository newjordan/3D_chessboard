generator client {
  provider        = "prisma-client-js"
  engineType      = "client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  username      String?   @unique
  passwordHash  String?
  role          Role      @default(user)
  createdAt     DateTime  @default(now())
  engines       Engine[]
  submissions   Submission[]
  runnerKeys    RunnerKey[]
  runnerKeyRequests RunnerKeyRequest[]

  // NextAuth
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum EngineStatus {
  pending
  active
  rejected
  banned
  disabled
  disabled_by_owner
}

enum Division {
  open
  js
  python
  lite
}

model Engine {
  id               String       @id @default(uuid())
  ownerUserId      String
  name             String
  slug             String       @unique
  description      String?
  status           EngineStatus @default(pending)
  division         Division     @default(open)
  currentVersionId String?
  currentRating    Int          @default(1200)
  currentRank      Int?
  gamesPlayed      Int          @default(0)
  wins             Int          @default(0)
  losses           Int          @default(0)
  draws            Int          @default(0)
  avatarUrl        String?
  pieceUrl         String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  owner            User         @relation(fields: [ownerUserId], references: [id])
  versions         EngineVersion[]
  matchesChallenged Match[]     @relation("ChallengerEngine")
  matchesDefended   Match[]     @relation("DefenderEngine")
  matchesWon       Match[]      @relation("WinnerEngine")
  gamesAsWhite     Game[]       @relation("WhiteEngine")
  gamesAsBlack     Game[]       @relation("BlackEngine")
  ratings          Rating[]
}

enum ValidationStatus {
  pending
  running
  passed
  failed
}

model EngineVersion {
  id               String           @id @default(uuid())
  engineId         String
  versionLabel     String?
  storageKey       String
  sha256           String
  fileSizeBytes    Int
  targetArch       String           @default("x86_64-linux")
  isStaticBinary   Boolean          @default(false)
  validationStatus ValidationStatus @default(pending)
  validationNotes  String?
  uciName          String?
  uciAuthor        String?
  language         String?
  generationModel  String?
  submittedAt      DateTime         @default(now())
  validatedAt      DateTime?

  engine           Engine           @relation(fields: [engineId], references: [id], onDelete: Cascade)
  submissions      Submission[]
  matchesChallenged Match[]         @relation("ChallengerVersion")
  matchesDefended   Match[]         @relation("DefenderVersion")

  @@unique([engineId, sha256], name: "engineId_sha256")
}

enum SubmissionStatus {
  uploaded
  validating
  validated
  rejected
  queued_for_placement
  placed
}

model Submission {
  id               String           @id @default(uuid())
  engineVersionId  String
  submittedByUserId String
  status           SubmissionStatus @default(uploaded)
  rejectionReason  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  version          EngineVersion    @relation(fields: [engineVersionId], references: [id], onDelete: Cascade)
  submitter        User             @relation(fields: [submittedByUserId], references: [id])
}

enum MatchType {
  placement
  rating
  admin
}

enum MatchStatus {
  queued
  running
  completed
  failed
  canceled
}

model Match {
  id                  String      @id @default(uuid())
  matchType           MatchType
  challengerEngineId  String
  defenderEngineId    String
  challengerVersionId String
  defenderVersionId   String
  status              MatchStatus @default(queued)
  timeControl         String
  gamesPlanned        Int
  gamesCompleted      Int         @default(0)
  challengerScore     Decimal?    @db.Decimal(5, 2)
  defenderScore       Decimal?    @db.Decimal(5, 2)
  winnerEngineId      String?
  pgnStorageKey       String?
  logStorageKey       String?
  startedAt           DateTime?
  completedAt         DateTime?
  processedBy         String?
  createdAt           DateTime    @default(now())

  challengerEngine    Engine      @relation("ChallengerEngine", fields: [challengerEngineId], references: [id])
  defenderEngine      Engine      @relation("DefenderEngine", fields: [defenderEngineId], references: [id])
  challengerVersion   EngineVersion @relation("ChallengerVersion", fields: [challengerVersionId], references: [id])
  defenderVersion     EngineVersion @relation("DefenderVersion", fields: [defenderVersionId], references: [id])
  winnerEngine        Engine?     @relation("WinnerEngine", fields: [winnerEngineId], references: [id])
  games               Game[]
  ratings             Rating[]
}

model Game {
  id            String   @id @default(uuid())
  matchId       String
  roundIndex    Int
  whiteEngineId String
  blackEngineId String
  result        String   // '1-0', '0-1', '1/2-1/2'
  termination   String?
  openingName   String?
  plyCount      Int?
  pgnStorageKey String?
  createdAt     DateTime @default(now())

  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  whiteEngine   Engine   @relation("WhiteEngine", fields: [whiteEngineId], references: [id])
  blackEngine   Engine   @relation("BlackEngine", fields: [blackEngineId], references: [id])
}

model Rating {
  id            String   @id @default(uuid())
  engineId      String
  matchId       String
  ratingBefore  Int
  ratingAfter   Int
  delta         Int
  system        String   @default("elo")
  createdAt     DateTime @default(now())

  engine        Engine   @relation(fields: [engineId], references: [id], onDelete: Cascade)
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

enum JobType {
  submission_validate
  placement_prepare
  match_run
  rating_apply
}

enum JobStatus {
  pending
  processing
  completed
  failed
}

model Job {
  id          String    @id @default(uuid())
  jobType     JobType
  payloadJson Json
  status      JobStatus @default(pending)
  runAt       DateTime  @default(now())
  attempts    Int       @default(0)
  lastError   String?
  lockedAt    DateTime?
  workerId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt])
}

enum RunnerKeyRequestStatus {
  pending
  fulfilled
  rejected
}

model RunnerKeyRequest {
  id        String                 @id @default(uuid())
  userId    String
  note      String?                @db.Text
  status    RunnerKeyRequestStatus @default(pending)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RunnerKey {
  id                String    @id @default(uuid())
  userId            String
  label             String?
  publicKey         String    @db.Text
  privateKeyOnce    String?   @db.Text
  trusted           Boolean   @default(false)
  canRunPlacements  Boolean   @default(false)
  jobsProcessed     Int       @default(0)
  createdAt         DateTime  @default(now())
  revokedAt         DateTime?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServerKey {
  id         String   @id @default(uuid())
  publicKey  String   @db.Text
  privateKey String   @db.Text
  createdAt  DateTime @default(now())
}
